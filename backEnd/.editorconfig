[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
# This is the magic line that stops the HEADER_KEYWORD crash
ktlint_standard_header = disabled

# Other rules that commonly cause issues in Spring/Protobuf projects
ktlint_standard_no-consecutive-blank-lines = disabled
ktlint_standard_filename = disabled
ktlint_standard_package-name = disabled
ktlint_standard_no-wildcard-imports = disabled