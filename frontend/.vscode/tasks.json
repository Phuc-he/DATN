{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "fe",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^.*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting",
          "endsPattern": "successfully|listening|started"
        }
      }
    },
    {
      "label": "start-all",
      "dependsOn": [
        "fe"
      ],
      "dependsOrder": "parallel"
    },
    {
      "label": "Configure Git Global",
      "type": "shell",
      "command": "git config --global user.name 'Phuc-he'; git config --global user.email 'josphuc2k3@gmail.com'",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
    },
    {
      "label": "push force",
      "type": "shell",
      "command": "git push origin main --force",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
    }
  ]
}